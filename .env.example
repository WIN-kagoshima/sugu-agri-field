# SuguAgriField MCP server — example environment variables
# Copy to .env for local development. Never commit .env.

# ----- Runtime -----
# Port for Streamable HTTP transport (Phase 1+)
PORT=3001

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# ----- Public URLs -----
# Public base URL the server is reachable at (used in Server Card and elicitation URLs).
# In dev, http://localhost:3001 is fine.
MCP_BASE_URL=http://localhost:3001

# ----- Data sources -----
# Open-Meteo requires no key. Override only if a paid plan is in use.
# OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Snapshot SQLite paths (Phase 1+). Defaults relative to project root.
EMAFF_SNAPSHOT_PATH=./snapshots/emaff-fude-kagoshima.sqlite
FAMIC_SNAPSHOT_PATH=./snapshots/famic-pesticide-2026.sqlite

# ----- OAuth (Phase 4) -----
# Demo / dummy OAuth provider used for the URL elicitation flow.
# Replace with real provider credentials when wiring up WAGRI / etc. in Phase 7.
DEMO_OAUTH_CLIENT_ID=demo-client-id
DEMO_OAUTH_CLIENT_SECRET=demo-client-secret
DEMO_OAUTH_AUTHORIZE_URL=http://localhost:3001/__mock-oauth/authorize
DEMO_OAUTH_TOKEN_URL=http://localhost:3001/__mock-oauth/token

# Cookie signing key for the /connect/{provider} session check.
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_COOKIE_SECRET=please-replace-with-a-32-byte-hex-string

# Encrypted-file token store key. Required in any environment where the
# OAuth URL flow is enabled and tokens must survive restarts. Without
# either of these, the server falls back to an in-memory store and logs
# a warning at startup.
#
# 32-byte AES-256 key, base64-encoded. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# SUGU_TOKEN_ENC_KEY=

# Or a passphrase the server hashes (scrypt) into a 32-byte key. A salt
# is created on first run at $SUGU_TOKEN_DIR/.salt.
# SUGU_TOKEN_ENC_PASSPHRASE=

# Directory for encrypted token files. Defaults to ./.tokens.
# SUGU_TOKEN_DIR=./.tokens

# ----- Production-only (do NOT set in dev) -----
# GCP_PROJECT_ID=
# CLOUD_RUN_SERVICE_ACCOUNT=
