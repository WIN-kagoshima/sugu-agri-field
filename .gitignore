# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
*.tsbuildinfo
.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Test
coverage/
.nyc_output/
