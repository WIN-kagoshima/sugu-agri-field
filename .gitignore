snapshots/*.sqlite
snapshots/*.sqlite-*
snapshots/raw/
!snapshots/README.md
!snapshots/.gitkeep

# Cloud Run / build artifacts
.gcloudignore-effective
build/

# Token store (Phase 4 dev only — never commit)
.tokens/
